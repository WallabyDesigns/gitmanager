APP_NAME="Git Web Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

GWM_SELF_UPDATE_MODE=in_place
GWM_RELEASES_PATH=./releases
GWM_COMPOSER_BINARY=
GWM_GIT_BINARY=git
GWM_NPM_BINARY=
GWM_PHP_BINARY=
GWM_PHP_PATH=
GWM_PROCESS_PATH=
GWM_ASKPASS_DIR=
GWM_SELF_UPDATE_ENABLED=
GWM_SELF_UPDATE_EXCLUDE_PATHS=docs
GWM_PREVIEW_PATH=
GWM_PREVIEW_BASE_URL=
GWM_DEPLOY_QUEUE_ENABLED=true
GWM_DEPLOY_STAGING_ENABLED=true
GWM_DEPLOY_STAGING_PATH=
GWM_SCHEDULER_STALE_SECONDS=120

# Legacy GPM_* keys are still supported for backward compatibility.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
